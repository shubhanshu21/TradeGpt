# Delta Exchange India API Configuration
# Get your keys from: https://www.india.delta.exchange/app/account/api-management
DELTA_API_KEY=YOUR_DELTA_API_KEY
DELTA_API_SECRET=YOUR_DELTA_API_SECRET
DELTA_TESTNET=true

# Telegram Alert Configuration (Optional)
# Create a bot with @BotFather and get your Chat ID with @userinfobot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ─── LLM Reasoning Layer (Optional) ──────────────────────
# Set LLM_ENABLED=true to activate the hybrid logic model
LLM_ENABLED=false

# Providers: ollama | openai | anthropic | groq
LLM_PROVIDER=ollama
LLM_MODEL=mistral
LLM_API_KEY=YOUR_LLM_API_KEY
OLLAMA_URL=http://localhost:11434

# ─── Sentiment Analysis (Optional) ──────────────────────
# Get your key from: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=YOUR_CRYPTOPANIC_API_KEY
